{
  "name": "@helios/subgraph",
  "version": "0.7.0",
  "private": true,
  "description": "Goldsky subgraph indexing Helios contract events across Kite, Base, and Arbitrum.",
  "scripts": {
    "codegen": "graph codegen",
    "codegen:base": "graph codegen subgraph.base-sepolia.yaml",
    "codegen:arbitrum": "graph codegen subgraph.arbitrum-sepolia.yaml",
    "codegen:all": "pnpm codegen && pnpm codegen:base && pnpm codegen:arbitrum",
    "build": "graph build",
    "build:base": "graph build subgraph.base-sepolia.yaml",
    "build:arbitrum": "graph build subgraph.arbitrum-sepolia.yaml",
    "build:all": "pnpm build && pnpm build:base && pnpm build:arbitrum",
    "typecheck": "pnpm codegen:all && pnpm build:all",
    "test": "graph test",
    "deploy": "goldsky subgraph deploy helios/v0.7.0 --path .",
    "deploy:base": "goldsky subgraph deploy helios-base/v0.5.0 --path . --subgraph-yaml subgraph.base-sepolia.yaml",
    "deploy:arbitrum": "goldsky subgraph deploy helios-arbitrum/v0.5.0 --path . --subgraph-yaml subgraph.arbitrum-sepolia.yaml",
    "create-local": "graph create --node http://localhost:8020/ helios",
    "remove-local": "graph remove --node http://localhost:8020/ helios",
    "deploy-local": "graph deploy --node http://localhost:8020/ --ipfs http://localhost:5001 helios"
  },
  "devDependencies": {
    "@goldskycom/cli": "^13.3.4",
    "@graphprotocol/graph-cli": "0.83.0",
    "@graphprotocol/graph-ts": "0.31.0",
    "matchstick-as": "^0.5.2"
  }
}
