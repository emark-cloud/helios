# Production env template — copy to /srv/helios/.env on the box and fill in.
# This file is committed; the real /srv/helios/.env is NEVER committed.

# ── Postgres ────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me

# ── Chains ──────────────────────────────────────────────────
KITE_RPC_URL=https://rpc-testnet.gokite.ai
KITE_CHAIN_ID=2368
BASE_SEPOLIA_RPC_URL=
ARBITRUM_SEPOLIA_RPC_URL=

# ── Signer keys (load from secret store, not version control) ─
KITE_PASSPORT_SIGNER_PK=
DEPLOYER_PK=
REPUTATION_SIGNER_PK=
ORACLE_SIGNER_PK=

# ── Indexer ─────────────────────────────────────────────────
GOLDSKY_API_KEY=
# WS11.7 cutover — v0.7.1 indexes the new SR-v3 + AR-v2 + v2-bis
# anchor + new Kite OApp. v0.6.0 still live for fallback.
# (v0.7.0 was paused by Goldsky on 2026-05-13; srcChainId handler
# regression fixed in commit 0375944 and redeployed as v0.7.1.)
GOLDSKY_ENDPOINT=https://api.goldsky.com/api/public/project_cmodpmbv1pkd70127d9g741ek/subgraphs/helios/v0.7.1/gn

# ── Telegram ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Ports (services listen on these inside their containers) ─
SENTINEL_HTTP_PORT=8001
REPUTATION_HTTP_PORT=8002
ORACLE_HTTP_PORT=8003
PROVER_HTTP_PORT=8004
BOT_HTTP_PORT=8005

ENVIRONMENT=production
LOG_LEVEL=info
SCENARIO_MODE=0

# ── Phase-6 real-price cutover (`docs/phase6-realprice-plan.md`) ─
# Enable the oracle's RouterPriceMirror keeper (WS2). Each oracle
# bar mirrors signed prices into MockSwapRouter.setPrice for the
# four configured legs so synthetic liquidity tracks live BTC/ETH/
# SOL prices. Disabled by default — flip ROUTER_MIRROR_ENABLED=1
# after WS8 broadcast lands the test universe + Phase-6 vaults.
ROUTER_MIRROR_ENABLED=0
ROUTER_MIRROR_ADDRESS=
ROUTER_MIRROR_SIGNER_PK=
ROUTER_MIRROR_SPREAD_BPS=5
# Universe token addresses — populated by DeployTestUniverse.s.sol
# (WBTC/WETH/WSOL) and the existing mUSDC. Keeper only mirrors a
# leg if both stable + asset legs are non-empty, so partial
# population is a graceful no-op.
ROUTER_MIRROR_TOKEN_USDC=
ROUTER_MIRROR_TOKEN_WBTC=
ROUTER_MIRROR_TOKEN_WETH=
ROUTER_MIRROR_TOKEN_WSOL=
# Real-world decimals. mUSDC on Kite testnet is 18 (MockERC20
# default — overrides this default of 6 when ROUTER_MIRROR_TOKEN_USDC
# resolves to the legacy mUSDC at 0xe8cf8a57…). Override to 18 if
# pointing at the legacy 18-dec mUSDC, or leave at 6 if WS8
# redeploys mUSDC at 6 decimals.
ROUTER_MIRROR_USDC_DECIMALS=18
ROUTER_MIRROR_WBTC_DECIMALS=8
ROUTER_MIRROR_WETH_DECIMALS=18
ROUTER_MIRROR_WSOL_DECIMALS=9

# Reference-strategy multi-asset witness encoding (WS3). Empty
# string keeps the Phase-1 USD*10^18 legacy mode; set to a JSON
# object once WS8 broadcasts so witnesses encode `amount_in` in
# the tokenIn's native decimals (required for on-chain swap
# amount to match publicInputs[PI_AMOUNT_IN]).
MOMENTUM_ASSET_DECIMALS_JSON=
MEAN_REV_ASSET_DECIMALS_JSON=

# Phase-6 StrategyVault proxies + the MockSwapRouter inventory
# pool. All blank pre-broadcast — WS8 fills these in from
# `contracts/broadcast/DeployPhase6MultiAssetVaults.s.sol/2368/run-latest.json`.
MOCK_SWAP_ROUTER_ADDRESS=
MOMENTUM_STRATEGY_VAULT_ADDRESS=
MEAN_REV_STRATEGY_VAULT_ADDRESS=
YIELD_ROTATION_STRATEGY_VAULT_ADDRESS=
# Sentinel's chain-watcher fan-out — comma-separated Phase-6 vault
# proxies. Auto-resolves NavDivergenceObserved fan-out to subscribed
# users; can stay empty in stub mode.
SENTINEL_CHAIN_WATCH_STRATEGY_VAULTS=

# ── WS9 — autonomous attested-trade bring-up (`docs/phase6-plan.md` WS9) ─
# These three blocks make the deployed strategy services fire
# `TradeAttested` events on every bar where a class signal exceeds
# threshold, no script and no manual intervention. See
# `/home/emark/.claude/plans/dazzling-spinning-quokka.md` for the full plan.

# 1. Tighten oracle anchor cadence so the strategy's per-bar witness
#    root always lands inside the 180s `MAX_ORACLE_STALENESS_SEC`
#    window enforced at `StrategyVault._validateAndVerify`. Default
#    50 commits a root every 50 minutes — far outside the freshness
#    budget. Set to 1 to commit every bar (3 txs/min on KITE testnet
#    is fine).
ORACLE_ANCHOR_INTERVAL_BARS=1

# Window depth that the on-chain anchor commits and the strategy
# circuit consumes. MUST equal `PRICE_OBSERVATIONS = LOOKBACK_BARS = 16`
# in every reference strategy (`reference-strategies/*/witness.py`).
# A lower depth (e.g. 4) makes the CommitMirror store windows that
# `/v1/snapshots/root?n=16` can't serve as `view=committed`, so the
# endpoint falls through to a live root that the anchor never signed —
# every `executeWithProof` then reverts `UnknownOracleRoot()`.
ORACLE_ANCHOR_CHAIN_DEPTH=16

# 2. Strategy operator + NAV-oracle signing keys. The Phase-6 deploy
#    set every vault's `manifest.operator` and `manifest.navOracle`
#    to the deployer address, so all four PKs resolve to `$DEPLOYER_PK`.
#    Without these the strategy services run in dry-run mode (NAV
#    reports stay unsigned, `executeWithProof` never broadcasts).
MOMENTUM_OPERATOR_PK=
MEAN_REV_OPERATOR_PK=
YIELD_ROT_OPERATOR_PK=
NAV_ORACLE_PK=

# 3. 8-entry on-chain ERC-20 address list per class — the strategy's
#    `asset_universe` (token symbols) maps 1:1 to these slots. Required
#    for the witness to encode real `assetIn`/`assetOut` indices for
#    `executeWithProof`. Phase-6 momentum + mean-reversion vaults use
#    `[mUSDC, mWBTC, mWETH, mSOL]`, padded with empty strings to length
#    8. Yield-rotation has no asset universe (no JSON needed).
MOMENTUM_ASSET_UNIVERSE_ADDRESSES_JSON=
MEAN_REV_ASSET_UNIVERSE_ADDRESSES_JSON=

# 4. Allocator + StrategyRegistry addresses. The runtime's witness
#    builder embeds the allocator in `publicInputs[PI_ALLOCATOR]` for
#    the on-chain match check; the registry is read once per
#    container start to commit the strategy's Poseidon paramsHash via
#    `commitInitialParamsHash` (idempotent — restarts read-and-skip).
ALLOCATOR_ADDRESS=
# WS11 V1→V2 cutover (2026-05-11): use SR-v3 + AR-v2 + v2-bis. The
# previous SR-v2 (0x7E707C8A…) and V1 SR (0x3A0f5B94…) keep their
# committed state but are no longer the live source of truth for new
# allocations or new strategy paramsHash commits.
STRATEGY_REGISTRY=0xe6c2cfCa8fd59f4b6fCF0b5F83A515aBB7498D35
SENTINEL_ALLOCATOR_REGISTRY_ADDRESS=0xb673e6F8f11fb416B47f5d9C0a36400bF9485A06
REPUTATION_ANCHOR_ADDRESS=0x2b6c5f3648Ae2aA27c80CB871590D1Ef1346938D
REPUTATION_TYPEHASH_VERSION=2
# WS11.6 — new Kite OApp pointing at v2-bis (predecessor 0x7Bad5250…
# null-anchor stays parked).
NEXT_PUBLIC_HELIOS_OAPP_KITE=0x9845c0C697964464dCAF2602b4e516CaEA98E51E
