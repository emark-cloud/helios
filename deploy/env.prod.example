# Production env template — copy to /srv/helios/.env on the box and fill in.
# This file is committed; the real /srv/helios/.env is NEVER committed.

# ── Postgres ────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me

# ── Chains ──────────────────────────────────────────────────
KITE_RPC_URL=https://rpc-testnet.gokite.ai
KITE_CHAIN_ID=2368
BASE_SEPOLIA_RPC_URL=
ARBITRUM_SEPOLIA_RPC_URL=

# ── Signer keys (load from secret store, not version control) ─
KITE_PASSPORT_SIGNER_PK=
DEPLOYER_PK=
REPUTATION_SIGNER_PK=
ORACLE_SIGNER_PK=

# ── Indexer ─────────────────────────────────────────────────
GOLDSKY_API_KEY=
GOLDSKY_ENDPOINT=

# ── Telegram ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Ports (services listen on these inside their containers) ─
SENTINEL_HTTP_PORT=8001
REPUTATION_HTTP_PORT=8002
ORACLE_HTTP_PORT=8003
PROVER_HTTP_PORT=8004
BOT_HTTP_PORT=8005

ENVIRONMENT=production
LOG_LEVEL=info
SCENARIO_MODE=0
