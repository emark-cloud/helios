# Production env template — copy to /srv/helios/.env on the box and fill in.
# This file is committed; the real /srv/helios/.env is NEVER committed.

# ── Postgres ────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me

# ── Chains ──────────────────────────────────────────────────
KITE_RPC_URL=https://rpc-testnet.gokite.ai
KITE_CHAIN_ID=2368
BASE_SEPOLIA_RPC_URL=
ARBITRUM_SEPOLIA_RPC_URL=

# ── Signer keys (load from secret store, not version control) ─
KITE_PASSPORT_SIGNER_PK=
DEPLOYER_PK=
REPUTATION_SIGNER_PK=
ORACLE_SIGNER_PK=

# ── Indexer ─────────────────────────────────────────────────
GOLDSKY_API_KEY=
GOLDSKY_ENDPOINT=

# ── Telegram ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Ports (services listen on these inside their containers) ─
SENTINEL_HTTP_PORT=8001
REPUTATION_HTTP_PORT=8002
ORACLE_HTTP_PORT=8003
PROVER_HTTP_PORT=8004
BOT_HTTP_PORT=8005

ENVIRONMENT=production
LOG_LEVEL=info
SCENARIO_MODE=0

# ── Phase-6 real-price cutover (`docs/phase6-realprice-plan.md`) ─
# Enable the oracle's RouterPriceMirror keeper (WS2). Each oracle
# bar mirrors signed prices into MockSwapRouter.setPrice for the
# four configured legs so synthetic liquidity tracks live BTC/ETH/
# SOL prices. Disabled by default — flip ROUTER_MIRROR_ENABLED=1
# after WS8 broadcast lands the test universe + Phase-6 vaults.
ROUTER_MIRROR_ENABLED=0
ROUTER_MIRROR_ADDRESS=
ROUTER_MIRROR_SIGNER_PK=
ROUTER_MIRROR_SPREAD_BPS=5
# Universe token addresses — populated by DeployTestUniverse.s.sol
# (WBTC/WETH/WSOL) and the existing mUSDC. Keeper only mirrors a
# leg if both stable + asset legs are non-empty, so partial
# population is a graceful no-op.
ROUTER_MIRROR_TOKEN_USDC=
ROUTER_MIRROR_TOKEN_WBTC=
ROUTER_MIRROR_TOKEN_WETH=
ROUTER_MIRROR_TOKEN_WSOL=
# Real-world decimals. mUSDC on Kite testnet is 18 (MockERC20
# default — overrides this default of 6 when ROUTER_MIRROR_TOKEN_USDC
# resolves to the legacy mUSDC at 0xe8cf8a57…). Override to 18 if
# pointing at the legacy 18-dec mUSDC, or leave at 6 if WS8
# redeploys mUSDC at 6 decimals.
ROUTER_MIRROR_USDC_DECIMALS=18
ROUTER_MIRROR_WBTC_DECIMALS=8
ROUTER_MIRROR_WETH_DECIMALS=18
ROUTER_MIRROR_WSOL_DECIMALS=9

# Reference-strategy multi-asset witness encoding (WS3). Empty
# string keeps the Phase-1 USD*10^18 legacy mode; set to a JSON
# object once WS8 broadcasts so witnesses encode `amount_in` in
# the tokenIn's native decimals (required for on-chain swap
# amount to match publicInputs[PI_AMOUNT_IN]).
MOMENTUM_ASSET_DECIMALS_JSON=
MEAN_REV_ASSET_DECIMALS_JSON=

# Phase-6 StrategyVault proxies + the MockSwapRouter inventory
# pool. All blank pre-broadcast — WS8 fills these in from
# `contracts/broadcast/DeployPhase6MultiAssetVaults.s.sol/2368/run-latest.json`.
MOCK_SWAP_ROUTER_ADDRESS=
MOMENTUM_STRATEGY_VAULT_ADDRESS=
MEAN_REV_STRATEGY_VAULT_ADDRESS=
YIELD_ROTATION_STRATEGY_VAULT_ADDRESS=
# Sentinel's chain-watcher fan-out — comma-separated Phase-6 vault
# proxies. Auto-resolves NavDivergenceObserved fan-out to subscribed
# users; can stay empty in stub mode.
SENTINEL_CHAIN_WATCH_STRATEGY_VAULTS=
