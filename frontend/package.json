{
  "name": "@helios/frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Helios web app — Next.js 14 App Router. See DESIGN.md for the design brief.",
  "scripts": {
    "dev": "next dev -p 3000",
    "prebuild": "pnpm --filter @helios/contracts-abi build",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "next build && playwright test",
    "test:e2e:update": "next build && playwright test --update-snapshots"
  },
  "dependencies": {
    "@gokite-network/auth": "0.1.16",
    "@helios/contracts-abi": "workspace:*",
    "@particle-network/auth": "1.3.1",
    "@particle-network/connectkit": "3.0.0-alpha.4",
    "@tanstack/react-query": "^5.62.0",
    "dotenv": "^17.4.2",
    "gokite-aa-sdk": "1.0.15",
    "next": "^14.2.20",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "viem": "^2.21.55",
    "wagmi": "^2.14.6",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
