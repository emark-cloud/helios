# Helios environment template. Copy to `.env` and fill in.
# Secrets never commit. Local dev uses .env; prod uses Vercel/VPS env.

# ── Chain RPCs ──────────────────────────────────────────────
KITE_RPC_URL=https://rpc-testnet.gokite.ai
KITE_CHAIN_ID=2368
BASE_SEPOLIA_RPC_URL=
BASE_SEPOLIA_CHAIN_ID=84532
ARBITRUM_SEPOLIA_RPC_URL=
ARBITRUM_SEPOLIA_CHAIN_ID=421614

# ── Signer keys (NEVER commit) ──────────────────────────────
# Deployer key for contracts (Kite/Base/Arbitrum)
DEPLOYER_PK=
# Registered signer that posts to ReputationAnchor
REPUTATION_SIGNER_PK=
# Price + yield oracle signing key
ORACLE_SIGNER_PK=

# ── Postgres ────────────────────────────────────────────────
DATABASE_URL=postgres://helios:helios@localhost:5432/helios

# ── Goldsky ─────────────────────────────────────────────────
GOLDSKY_API_KEY=
# Phase 1 Kite testnet subgraph (deployed 2026-04-27 against Track B addresses).
GOLDSKY_ENDPOINT=https://api.goldsky.com/api/public/project_cmodpmbv1pkd70127d9g741ek/subgraphs/helios/v0.2.0/gn

# ── Frontend ────────────────────────────────────────────────
NEXT_PUBLIC_KITE_CHAIN_ID=2368
NEXT_PUBLIC_GOLDSKY_ENDPOINT=https://api.goldsky.com/api/public/project_cmodpmbv1pkd70127d9g741ek/subgraphs/helios/v0.2.0/gn
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
# Sentinel REST/WS base URL — defaults to local docker-compose.
NEXT_PUBLIC_SENTINEL_URL=http://localhost:8001
# Kite Passport (Particle Network-backed). Required for the production
# /onboard flow; keep empty to fall back to EIP-191 personal_sign for
# anvil/e2e dev (controlled by NEXT_PUBLIC_USE_PASSPORT below).
# Pull projectId/clientKey/appId from https://dashboard.particle.network.
NEXT_PUBLIC_PARTICLE_PROJECT_ID=
NEXT_PUBLIC_PARTICLE_CLIENT_KEY=
NEXT_PUBLIC_PARTICLE_APP_ID=
# ERC-4337 EntryPoint + factory addresses on Kite testnet (chain 2368).
# Verify against https://docs.gokite.ai before each deploy — Kite
# rotates these between testnet/mainnet, and gokite-aa-sdk@1.0.15 binds
# verifier-adapter ABIs to specific deployments.
NEXT_PUBLIC_AA_ENTRYPOINT_ADDRESS=
NEXT_PUBLIC_AA_FACTORY_ADDRESS=
# Toggle for the Passport flow. "1" or "true" enables; anything else
# (or unset) keeps the EIP-191 personal_sign fallback so anvil-based
# e2e (`scripts/e2e-scenario.sh`) can sign with deterministic test
# keys. Production builds must set this to "1".
NEXT_PUBLIC_USE_PASSPORT=
# Sentinel allocator EOA — the owner the user delegates to in the
# fourth call of the onboarding userOp batch.
NEXT_PUBLIC_SENTINEL_ALLOCATOR_ADDRESS=

# ── Services ────────────────────────────────────────────────
SENTINEL_HTTP_PORT=8001
REPUTATION_HTTP_PORT=8002
ORACLE_HTTP_PORT=8003
PROVER_HTTP_PORT=8004
# Bearer token required on POST /prove. Empty string disables auth
# (default for local dev / CI). Production VPS deploys MUST set a
# random secret here — without it any HTTP caller can burn CPU on the
# prover. Strategy runtimes pass the token via `PROVER_AUTH_TOKEN` too.
PROVER_AUTH_TOKEN=
# Cap on concurrent in-flight proof generations. 4 is comfortable for
# a 4-vCPU VPS; bursts past this get 429 with Retry-After=5.
PROVER_MAX_CONCURRENT=4
BOT_HTTP_PORT=8005

# Comma-separated CORS origins for FastAPI services (sentinel, oracle,
# reputation, helix, bot). Local dev defaults to the Next.js host;
# production must list the public frontend host(s) explicitly — `*` is
# rejected when paired with `allow_credentials=True`.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Telegram ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Deployment ──────────────────────────────────────────────
VERCEL_TOKEN=
VPS_SSH=

# ── Modes ───────────────────────────────────────────────────
# 1 = deterministic market replay (integration testbed + demo)
SCENARIO_MODE=0
SCENARIO_FILE=scenarios/phase1-drawdown.json
