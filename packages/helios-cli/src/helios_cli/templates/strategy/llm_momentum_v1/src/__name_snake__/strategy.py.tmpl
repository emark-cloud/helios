"""{{NAME_PASCAL}}Strategy — your Claude-driven momentum_v1 signal.

The SDK runtime polls the price oracle, calls `on_bar` once per asset
per bar, generates the Groth16 proof for each `TradeIntent` you return,
and submits `executeWithProof` on chain. Your job is the *prompt*:
how should the model read the market and decide?

`declared_class = "momentum_v1"` so this strategy reuses the existing
momentum_v1 verifier on chain. The trade still has to satisfy the
circuit's invariants (Helios.md §10.2):
  * `asset_in`, `asset_out` ∈ `asset_universe`
  * `amount_in_usd ≤ max_position_size_usd`
  * `min_amount_out` respects `max_slippage_bps`
  * Direction matches *some* operator-declared threshold (LONG / EXIT)

`signal_threshold` is a private witness input — the on-chain `params_hash`
binds it without revealing the value. The LLM only sees a market context;
it cannot escape these bounds because the chain enforces them.
"""

from __future__ import annotations

import json
import os
from typing import Any

from helios import Direction, MarketSnapshot, StrategyAgent, TradeIntent


# TODO: edit this prompt to shape your agent's behavior. The system
# prompt is sent with prompt-caching enabled, so iteration is cheap.
SYSTEM_PROMPT = """You are a momentum trading agent on the Helios protocol.

Look at the recent price action for ONE asset and decide whether to go
LONG, EXIT an existing position, or HOLD. Be honest about confidence —
the runtime skips trades below 0.6 confidence, and you earn reputation
from realized performance over time, not from forcing trades.

Bias toward action when momentum is clearly accelerating; bias toward
EXIT when a long position's thesis appears to be breaking down.
"""


_DECISION_TOOL: dict[str, Any] = {
    "name": "decision",
    "description": "Emit a trading decision for the current bar.",
    "input_schema": {
        "type": "object",
        "properties": {
            "action": {"type": "string", "enum": ["LONG", "EXIT", "HOLD"]},
            "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
            "rationale": {"type": "string"},
        },
        "required": ["action", "confidence", "rationale"],
    },
}


class {{NAME_PASCAL}}Strategy(StrategyAgent):
    declared_class = "momentum_v1"
    asset_universe = ("USDC", "WKITE", "WETH")
    max_position_size_usd = 10_000
    fee_rate_bps = 2_000  # 20% perf fee on PnL above HWM

    def __init__(
        self,
        signal_threshold: float = 0.015,
        lookback_bars: int = 10,
        max_slippage_bps: int = 30,
        position_fraction: float = 0.5,
        *,
        model: str = "claude-haiku-4-5-20251001",
        min_confidence: float = 0.6,
    ) -> None:
        super().__init__()
        self._signal_threshold = signal_threshold
        self._lookback = lookback_bars
        self._max_slippage_bps = max_slippage_bps
        self._position_fraction = position_fraction
        self._model = model
        self._min_confidence = min_confidence
        self._client = None  # lazy — see _get_client

    def on_bar(self, asset: str, snapshot: MarketSnapshot) -> TradeIntent | None:
        if asset == "USDC":
            return None
        if len(snapshot.prices) < self._lookback + 1:
            return None

        position = self.position_for(asset)
        decision = self._ask_claude(asset, snapshot, position)
        if decision is None:
            return None

        action = decision["action"]
        confidence = float(decision["confidence"])
        if confidence < self._min_confidence or action == "HOLD":
            return None

        if action == "LONG" and position <= 0:
            return TradeIntent(
                asset_in="USDC",
                asset_out=asset,
                amount_in_usd=self._size(),
                direction=Direction.LONG,
                max_slippage_bps=self._max_slippage_bps,
                is_nav_targeted=True,
            )
        if action == "EXIT" and position > 0:
            return TradeIntent(
                asset_in=asset,
                asset_out="USDC",
                amount_in_asset=position,
                direction=Direction.EXIT,
                max_slippage_bps=self._max_slippage_bps,
                is_signal_flip=True,
            )
        return None

    def _ask_claude(
        self, asset: str, snapshot: MarketSnapshot, position: float
    ) -> dict[str, Any] | None:
        client = self._get_client()
        if client is None:
            return None
        recent = snapshot.prices[-(self._lookback + 1) :]
        ret = (recent[-1] - recent[0]) / recent[0] if recent[0] else 0.0
        context = {
            "asset": asset,
            "current_price": recent[-1],
            "lookback_bars": self._lookback,
            "lookback_return_pct": round(ret * 100, 4),
            "recent_prices_oldest_to_newest": [round(p, 6) for p in recent],
            "current_position_qty": position,
            "nav_usd": round(self.nav, 2),
        }
        try:
            response = client.messages.create(
                model=self._model,
                max_tokens=512,
                system=[
                    {
                        "type": "text",
                        "text": SYSTEM_PROMPT,
                        "cache_control": {"type": "ephemeral"},
                    }
                ],
                tools=[_DECISION_TOOL],
                tool_choice={"type": "tool", "name": "decision"},
                messages=[{"role": "user", "content": json.dumps(context)}],
            )
        except Exception:
            return None
        for block in getattr(response, "content", []) or []:
            if getattr(block, "type", None) == "tool_use":
                tool_input = getattr(block, "input", None)
                if isinstance(tool_input, dict) and tool_input.get("action") in {
                    "LONG",
                    "EXIT",
                    "HOLD",
                }:
                    return tool_input
        return None

    def _get_client(self) -> Any | None:
        if self._client is not None:
            return self._client
        try:
            import anthropic
        except ImportError:
            return None
        api_key = os.environ.get("ANTHROPIC_API_KEY")
        if not api_key:
            return None
        self._client = anthropic.Anthropic(api_key=api_key)
        return self._client

    def _size(self) -> float:
        return min(self.max_position_size_usd, self.nav * self._position_fraction)
