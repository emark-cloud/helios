[project]
name = "{{NAME_KEBAB}}"
version = "0.1.0"
description = "Helios llm_momentum_v1 strategy: {{NAME}} — Claude decides, the chain enforces."
requires-python = ">=3.11"
dependencies = [
    "helios-strategy-sdk>=0.1.0",
    "anthropic>=0.40.0",
]

[project.optional-dependencies]
dev = [
    "helios-trader-cli>=0.1.0",
    "pytest>=8.0",
]

[build-system]
requires = ["hatchling>=1.21"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{NAME_SNAKE}}"]
