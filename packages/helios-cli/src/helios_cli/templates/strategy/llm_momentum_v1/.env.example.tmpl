# {{NAME}} — runtime environment.
#
# Copy this file to `.env` and fill in. The runtime reads these on
# `python -m {{NAME_SNAKE}}` boot — missing required vars are fatal.

# ── Required ────────────────────────────────────────────────────

# Kite testnet RPC (chain id 2368 today; mainnet 2366 at Phase 6).
KITE_RPC_URL=https://rpc-testnet.gokite.ai

# Helios oracle endpoint — signs the price snapshots your trades commit to.
HELIOS_ORACLE_URL=https://oracle.helios.market

# Helios prover endpoint — generates the Groth16 proof for each trade.
HELIOS_PROVER_URL=https://prover.helios.market

# Strategy operator EOA. Signer for executeWithProof. Never commit.
STRATEGY_OPERATOR_PK=0x...

# This strategy's StrategyVault address. `helios stake top-up` prints
# it after registration confirms.
STRATEGY_VAULT=0x...

# Anthropic API key. Read directly by the SDK — the strategy refuses
# to fire trades when this is unset (skip-bar with structured log).
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional ────────────────────────────────────────────────────

# Anthropic model id. Defaults to Haiku for cost/latency.
LLM_MOMENTUM_ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Confidence floor — model decisions below this are treated as HOLD.
LLM_MOMENTUM_MIN_CONFIDENCE=0.6

# Bar interval for the runtime polling loop (seconds). 60s is a
# typical default — tighten for faster reaction, loosen for fewer txs.
BAR_INTERVAL_SEC=60
