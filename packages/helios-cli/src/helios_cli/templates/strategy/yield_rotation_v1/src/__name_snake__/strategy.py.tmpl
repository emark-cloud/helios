"""{{NAME_PASCAL}}Strategy — your yield_rotation_v1 rotation logic.

The SDK runtime polls the yield oracle and drives `on_yield_tick`
once per yield-snapshot tick — a different cadence from price bars,
which is why YR strategies do not implement `on_bar`. Your job is the
ranker: when has APY divergence between two markets exceeded
`signal_threshold + bridging_cost` enough to justify rotating
capital?

Class invariants enforced by `yield_rotation_v1.circom` (Helios.md §10.4):
  * Both `m_from` and `m_to` are in the operator-declared allowlist
  * Both APY snapshots are members of the canonical yield-oracle root
  * `apy_to − apy_from ≥ signal_threshold + bridging_cost` (all in bps)
  * `m_from ≠ m_to` and `amount_rotating > 0`
  * `block.number ≤ block_window_end`

`signal_threshold_bps` and `bridging_cost_bps` are private witness
inputs — the chain only sees that *some* threshold + budget exist for
which the rotation is consistent. That's your IP.
"""

from __future__ import annotations

from collections.abc import Sequence
from typing import ClassVar

from helios import (
    MarketSnapshot,
    RotationIntent,
    StrategyAgent,
    TradeIntent,
    YieldTick,
)


class {{NAME_PASCAL}}Strategy(StrategyAgent):
    declared_class = "yield_rotation_v1"
    # YR has no asset universe — markets are identified by integer
    # market IDs, allowlisted at construction time.
    asset_universe: ClassVar[Sequence[str]] = ()
    max_position_size_usd = 25_000
    fee_rate_bps = 1_500  # 15% perf fee — tighter than directional classes

    def __init__(
        self,
        *,
        allowlisted_markets: Sequence[int] = (1, 2, 3),
        signal_threshold_bps: int = 80,
        bridging_cost_bps: int = 30,
        position_fraction: float = 0.5,
    ) -> None:
        super().__init__()
        self._allowlisted_markets = tuple(allowlisted_markets)
        self._signal_threshold_bps = signal_threshold_bps
        self._bridging_cost_bps = bridging_cost_bps
        self._position_fraction = position_fraction

    def on_bar(self, asset: str, snapshot: MarketSnapshot) -> TradeIntent | None:
        # YR is yield-driven; the runtime never calls `on_bar` for this
        # strategy class. Override `on_yield_tick` instead.
        del asset, snapshot
        return None

    def on_yield_tick(self, ticks: dict[int, YieldTick]) -> RotationIntent | None:
        """Default rule: rotate into the highest-APY allowlisted market
        when the differential beats `signal_threshold + bridging_cost`.
        Edit me — that's the whole point.
        """
        candidates = {m: t for m, t in ticks.items() if m in self._allowlisted_markets}
        if len(candidates) < 2:
            return None
        best = max(candidates, key=lambda m: candidates[m].apy_bps_e6)
        if self.active_market == best:
            return None
        if self.active_market is not None and self.active_market in candidates:
            from_market = self.active_market
        else:
            from_market = min(candidates, key=lambda m: candidates[m].apy_bps_e6)
        if from_market == best:
            return None
        from_apy_bps = candidates[from_market].apy_bps_e6 // 1_000_000
        to_apy_bps = candidates[best].apy_bps_e6 // 1_000_000
        if to_apy_bps - from_apy_bps < self._signal_threshold_bps + self._bridging_cost_bps:
            return None
        amount = min(
            float(self.max_position_size_usd),
            self.available_capital * self._position_fraction,
        )
        if amount <= 0:
            return None
        return RotationIntent(
            m_from=from_market,
            m_to=best,
            amount_in_usd=amount,
            apy_from_bps=from_apy_bps,
            apy_to_bps=to_apy_bps,
        )
