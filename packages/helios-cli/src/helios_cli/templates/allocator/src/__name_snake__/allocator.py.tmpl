"""{{NAME_PASCAL}}Allocator — your allocator's ranking + allocation logic.

The two abstract methods on `BaseAllocator` are the only thing you have
to implement; the SDK runtime handles user onboarding, the 60s
decision loop, on-chain tx submission, fee crystallization, defunding,
WebSocket events, and stake. Look up `helios_allocator.runtime` if you
need to reach into any of that.

Default scaffold: a Sentinel-style ranker (reputation × capacity ×
class-fit × binary fee-fit). Replace `_score` with whatever ranking
function you want — that's where allocators differentiate.

See `helios_allocator.helpers` for ready-made building blocks:
  • `regime.helix_fee_factor` — continuous fee penalty
  • `regime.btc_realized_vol_30d` — regime detector seed
  • `correlation.helix_greedy_pick` — correlation-aware top-K
"""

from __future__ import annotations

from helios_allocator import (
    AllocationTarget,
    BaseAllocator,
    MetaStrategy,
    StrategyCandidate,
)


class {{NAME_PASCAL}}Allocator(BaseAllocator):
    name = "{{NAME}}"
    # Phase-3 plan default: 4–6% range. Tune to your fee model.
    fee_rate_bps = 500
    supported_classes = ("momentum_v1", "mean_reversion_v1", "yield_rotation_v1")

    def rank_strategies(
        self,
        user: MetaStrategy,
        candidates: list[StrategyCandidate],
    ) -> list[float]:
        return [self._score(c, user) for c in candidates]

    def allocate(
        self,
        user: MetaStrategy,
        ranked: list[StrategyCandidate],
        capital: int,
    ) -> list[AllocationTarget]:
        if capital <= 0 or not ranked:
            return []
        scores = self.rank_strategies(user, ranked)
        eligible = [(c, s) for c, s in zip(ranked, scores, strict=True) if s > 0]
        eligible = eligible[: user.max_strategies_count]
        if not eligible:
            return []
        candidates = [c for c, _ in eligible]
        sub_scores = [s for _, s in eligible]
        return self.score_weighted_allocation(user, candidates, capital, scores=sub_scores)

    def _score(self, c: StrategyCandidate, user: MetaStrategy) -> float:
        # Sentinel-style baseline. Edit me — that's the whole point.
        fee_ok = 1.0 if c.fee_rate_bps <= user.max_fee_rate_bps else 0.0
        return (
            c.reputation_score
            * c.capacity_factor()
            * c.class_fit(user.allowed_strategy_classes)
            * fee_ok
        )
