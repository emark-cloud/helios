# {{NAME}} — runtime environment.
#
# Copy this file to `.env` and fill in. The runtime reads these on
# `python -m {{NAME_SNAKE}}` boot — missing required vars are fatal.

# ── Required ────────────────────────────────────────────────────

# Kite testnet RPC (chain id 2368 today; mainnet 2366 at Phase 6).
KITE_RPC_URL=https://rpc-testnet.gokite.ai

# Goldsky endpoint for the Helios subgraph. Read-only.
GOLDSKY_ENDPOINT=https://api.goldsky.com/api/public/<your-project>/subgraphs/helios/v1/gn

# Allocator operator EOA. The signer for tx submission. Never commit.
ALLOCATOR_OPERATOR_PK=0x...

# This allocator's AllocatorVault address. `helios-allocator stake top-up`
# prints this once the registration tx confirms.
ALLOCATOR_VAULT=0x...

# ── Optional ────────────────────────────────────────────────────

# Tick interval for the decision loop (seconds). Lower = faster reaction
# to drawdowns / regime changes; higher = fewer on-chain txs.
TICK_INTERVAL_SEC=60
