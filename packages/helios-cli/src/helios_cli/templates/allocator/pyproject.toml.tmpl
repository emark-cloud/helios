[project]
name = "{{NAME_KEBAB}}"
version = "0.1.0"
description = "Helios allocator: {{NAME}}"
requires-python = ">=3.11"
dependencies = [
    "helios-allocator-sdk>=0.1.0",
    "pydantic>=2.6,<3",
    "httpx>=0.27,<1",
]

[project.optional-dependencies]
dev = [
    "pytest>=8.0",
    "pytest-asyncio>=0.23",
]

[build-system]
requires = ["hatchling>=1.21"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{NAME_SNAKE}}"]
